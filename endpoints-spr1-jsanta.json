{
  "info": {
    "name": "Restaurant Management System — All Endpoints",
    "baseUrl": "http://localhost:5000/api/v1",
    "authHeader": "Authorization: Bearer <JWT_TOKEN>"
  },

  "commit1_product_category": {
    "description": "feat: add Product and Category schemas",
    "categories": [
      { "name": "List categories",   "method": "GET",    "url": "/categories",    "auth": false, "query": { "isActive": "true" } },
      { "name": "Get category",      "method": "GET",    "url": "/categories/:id","auth": false },
      { "name": "Create category",   "method": "POST",   "url": "/categories",    "auth": true, "roles": ["admin"],
        "body": { "name": "Italian", "description": "Traditional Italian cuisine", "image": "https://example.com/img.jpg" } },
      { "name": "Update category",   "method": "PUT",    "url": "/categories/:id","auth": true, "roles": ["admin"],
        "body": { "name": "Italian Cuisine", "isActive": true } },
      { "name": "Delete category",   "method": "DELETE", "url": "/categories/:id","auth": true, "roles": ["admin"] }
    ],
    "products": [
      { "name": "List products",  "method": "GET", "url": "/products", "auth": false,
        "query": { "type": "main_course", "category": "<categoryId>", "restaurant": "<restaurantId>", "isAvailable": "true" } },
      { "name": "Get product",    "method": "GET", "url": "/products/:id", "auth": false },
      { "name": "Create product", "method": "POST","url": "/products", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": {
          "name": "Spaghetti Carbonara", "description": "Classic Roman pasta", "price": 14.99,
          "type": "main_course", "category": "<categoryId>", "preparationTime": 20,
          "ingredients": [
            { "name": "Spaghetti",    "quantity": "200", "unit": "g",   "isAllergen": true  },
            { "name": "Guanciale",    "quantity": "100", "unit": "g",   "isAllergen": false },
            { "name": "Eggs",         "quantity": "2",   "unit": "",    "isAllergen": true  },
            { "name": "Pecorino",     "quantity": "50",  "unit": "g",   "isAllergen": true  },
            { "name": "Black pepper", "quantity": "1",   "unit": "tsp", "isAllergen": false }
          ],
          "image": "https://example.com/carbonara.jpg", "isAvailable": true
        }
      },
      { "name": "Update product", "method": "PUT",   "url": "/products/:id", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": { "price": 15.99, "isAvailable": false } },
      { "name": "Delete product (soft)", "method": "DELETE", "url": "/products/:id", "auth": true, "roles": ["admin","restaurant_admin"] }
    ]
  },

  "commit2_events": {
    "description": "feat: add Event schema for special events",
    "events": [
      { "name": "List events", "method": "GET", "url": "/events", "auth": false,
        "query": { "status": "scheduled", "restaurant": "<restaurantId>" },
        "note": "status: scheduled | ongoing | completed | cancelled" },
      { "name": "Get event",   "method": "GET", "url": "/events/:id", "auth": false },
      { "name": "Create event","method": "POST","url": "/events", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": {
          "name": "Valentine's Dinner 2025",
          "description": "Romantic evening with live music and a 5-course menu",
          "startDate": "2025-02-14T19:00:00.000Z",
          "endDate":   "2025-02-14T23:00:00.000Z",
          "capacity": 40, "price": 89.99,
          "additionalResources": [
            { "name": "Live Jazz Band",  "description": "3-piece ensemble", "cost": 500, "quantity": 1  },
            { "name": "Floral Decor",    "description": "Roses and candles","cost": 200, "quantity": 1  },
            { "name": "Champagne Toast", "description": "Per couple",       "cost": 25,  "quantity": 20 }
          ],
          "image": "https://example.com/valentine.jpg"
        }
      },
      { "name": "Update event", "method": "PUT",   "url": "/events/:id", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": { "capacity": 50, "price": 95.00 } },
      { "name": "Update event status", "method": "PATCH", "url": "/events/:id/status", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": { "status": "ongoing" }, "note": "Values: scheduled | ongoing | completed | cancelled" },
      { "name": "Delete event (soft)", "method": "DELETE", "url": "/events/:id", "auth": true, "roles": ["admin","restaurant_admin"] }
    ]
  },

  "commit3_menus": {
    "description": "feat: add menu management endpoints for restaurant admin",
    "menus": [
      { "name": "List menus", "method": "GET", "url": "/menus", "auth": false,
        "query": { "restaurant": "<restaurantId>", "menuType": "dinner", "isActive": "true" },
        "note": "menuType: breakfast | lunch | dinner | all_day | special" },
      { "name": "List menus by restaurant (nested)", "method": "GET", "url": "/restaurants/:restaurantId/menus", "auth": false },
      { "name": "Get menu",    "method": "GET",  "url": "/menus/:id", "auth": false },
      { "name": "Create menu", "method": "POST", "url": "/menus", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": {
          "name": "Dinner Menu — Spring 2025", "description": "Seasonal dinner selection",
          "menuType": "dinner", "validFrom": "2025-03-01T00:00:00.000Z", "validTo": "2025-05-31T23:59:59.000Z",
          "items": [
            { "product": "<productId1>", "displayOrder": 1, "isHighlighted": true,  "specialPrice": 12.99 },
            { "product": "<productId2>", "displayOrder": 2, "isHighlighted": false, "specialPrice": null  }
          ]
        }
      },
      { "name": "Update menu", "method": "PUT", "url": "/menus/:id", "auth": true, "roles": ["admin","restaurant_admin"],
        "body": { "name": "Dinner Menu — Spring 2025 (Updated)", "isActive": true } },
      { "name": "Add dish to menu",    "method": "POST",   "url": "/menus/:id/items",             "auth": true, "roles": ["admin","restaurant_admin"],
        "body": { "product": "<productId>", "displayOrder": 3, "isHighlighted": true, "specialPrice": 9.99 } },
      { "name": "Remove dish from menu","method": "DELETE", "url": "/menus/:id/items/:productId", "auth": true, "roles": ["admin","restaurant_admin"] },
      { "name": "Delete menu (soft)",   "method": "DELETE", "url": "/menus/:id",                 "auth": true, "roles": ["admin","restaurant_admin"] }
    ]
  },

  "commit4_search": {
    "description": "feat: add search and filter endpoints",
    "search": [
      { "name": "Global search", "method": "GET", "url": "/search", "auth": false,
        "query": { "q": "pizza" },
        "note": "Min 2 chars. Returns top 5 restaurants + top 10 products." },
      { "name": "Search restaurants", "method": "GET", "url": "/search/restaurants", "auth": false,
        "query": { "name": "bella", "category": "Italian", "city": "Madrid", "minRating": "4.0", "page": "1", "limit": "10" },
        "note": "All params optional. Sorted by rating DESC. Paginated." },
      { "name": "Search products", "method": "GET", "url": "/search/products", "auth": false,
        "query": { "name": "pasta", "type": "main_course", "category": "<categoryId>", "restaurant": "<restaurantId>", "minPrice": "5.00", "maxPrice": "20.00", "page": "1", "limit": "20" },
        "note": "All params optional. Sorted by price ASC. Paginated." }
    ]
  }
}